---
// Evralie W. Marces - Portfolio Website
// Based on the Canva Design Presentation
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Evralie W. Marces | Portfolio</title>
    <meta
      name="description"
      content="Personal portfolio of Evralie W. Marces, studying Bachelor of Science in Information Systems at Davao del Norte State College."
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme Initializer -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme") || "dark";
        if (theme === "light") {
          document.documentElement.classList.add("light-mode");
        } else {
          document.documentElement.classList.remove("light-mode");
        }
      })();
    </script>

    <style is:global>
      /* Design Tokens & Theme Variables */
      :root {
        --bg-color: #121111;
        --bg-color-alt: #1a1919;
        --text-color: #f5f3ef;
        --text-muted: #9c9996;
        --accent-color: #dfc29c; /* Elegant gold/bronze */
        --accent-glow: rgba(223, 194, 156, 0.35);
        --border-color: rgba(255, 255, 255, 0.08);
        --surface-color: rgba(255, 255, 255, 0.03);
        --surface-hover: rgba(255, 255, 255, 0.06);
        --nav-bg: rgba(18, 17, 17, 0.85);
        --dot-color: rgba(255, 255, 255, 0.04);
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        --font-serif: "Playfair Display", serif;
        --font-sans: "Outfit", sans-serif;
      }

      html.light-mode {
        --bg-color: #f7f5f0; /* Off-white / light beige */
        --bg-color-alt: #eeebe3;
        --text-color: #1a1919;
        --text-muted: #6e6b66;
        --accent-color: #c5a072;
        --accent-glow: rgba(197, 160, 114, 0.2);
        --border-color: rgba(0, 0, 0, 0.08);
        --surface-color: rgba(0, 0, 0, 0.02);
        --surface-hover: rgba(0, 0, 0, 0.04);
        --nav-bg: rgba(247, 245, 240, 0.85);
        --dot-color: rgba(0, 0, 0, 0.03);
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      }

      /* Global Reset */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        font-family: var(--font-sans);
        color: var(--text-color);
        background-color: var(--bg-color);
        transition: background-color 0.4s ease, color 0.4s ease;
      }

      body {
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
        background-image: radial-gradient(
            var(--dot-color) 1.5px,
            transparent 1.5px
          ),
          radial-gradient(var(--dot-color) 1.5px, transparent 1.5px);
        background-size: 32px 32px;
        background-position: 0 0, 16px 16px;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg-color);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--accent-color);
      }

      /* Glowing background orbs */
      .glow-orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(150px);
        opacity: 0.15;
        z-index: -2;
        pointer-events: none;
        transition: opacity 0.5s ease;
      }
      html.light-mode .glow-orb {
        opacity: 0.08;
      }
      .orb-1 {
        width: 400px;
        height: 400px;
        background: radial-gradient(
          circle,
          var(--accent-color) 0%,
          transparent 80%
        );
        top: 10%;
        left: -10%;
        animation: floatOrb 20s infinite alternate;
      }
      .orb-2 {
        width: 500px;
        height: 500px;
        background: radial-gradient(
          circle,
          var(--accent-color) 0%,
          transparent 80%
        );
        bottom: 10%;
        right: -10%;
        animation: floatOrb 25s infinite alternate-reverse;
      }

      @keyframes floatOrb {
        0% {
          transform: translate(0, 0) scale(1);
        }
        100% {
          transform: translate(50px, 50px) scale(1.1);
        }
      }

      /* Custom Cursor (Optional premium micro-interaction) */
      @media (min-width: 1025px) {
        body,
        a,
        button,
        .interactive-card,
        .tab-btn {
          cursor: none;
        }
        .custom-cursor {
          position: fixed;
          top: 0;
          left: 0;
          width: 8px;
          height: 8px;
          background-color: var(--accent-color);
          border-radius: 50%;
          pointer-events: none;
          z-index: 9999;
          transform: translate(-50%, -50%);
          transition: width 0.15s, height 0.15s, background-color 0.15s;
          opacity: 0;
        }
        .custom-cursor-ring {
          position: fixed;
          top: 0;
          left: 0;
          width: 32px;
          height: 32px;
          border: 1px solid var(--accent-color);
          border-radius: 50%;
          pointer-events: none;
          z-index: 9998;
          transform: translate(-50%, -50%);
          transition: width 0.2s, height 0.2s, border-color 0.2s,
            transform 0.05s ease-out;
          opacity: 0;
        }
        body:hover .custom-cursor,
        body:hover .custom-cursor-ring {
          opacity: 1;
        }
      }

      /* Navigation Bar */
      .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 80px;
        background: var(--nav-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-bottom: 1px solid var(--border-color);
        z-index: 1000;
        transition: transform 0.3s ease, background-color 0.4s ease;
      }
      .nav-container {
        max-width: 1400px;
        height: 100%;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo {
        font-family: var(--font-serif);
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-decoration: none;
        color: var(--text-color);
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .logo span {
        color: var(--accent-color);
      }
      .nav-menu {
        display: flex;
        align-items: center;
        gap: 32px;
      }
      .nav-link {
        text-decoration: none;
        color: var(--text-muted);
        font-weight: 500;
        font-size: 0.95rem;
        transition: color 0.3s ease;
        position: relative;
        padding: 6px 0;
      }
      .nav-link:hover,
      .nav-link.active {
        color: var(--text-color);
      }
      .nav-link::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background-color: var(--accent-color);
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.3s ease;
      }
      .nav-link:hover::after,
      .nav-link.active::after {
        transform: scaleX(1);
        transform-origin: left;
      }

      /* Control Group (Theme & Mode Switches) */
      .nav-controls {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      /* Theme Toggle Button */
      .theme-btn {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-color);
        transition: all 0.3s ease;
      }
      .theme-btn:hover {
        background: var(--surface-hover);
        border-color: var(--accent-color);
        transform: scale(1.05);
      }
      .theme-btn svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
      }
      .theme-btn .sun-icon {
        display: none;
      }
      .theme-btn .moon-icon {
        display: block;
      }
      html.light-mode .theme-btn .sun-icon {
        display: block;
      }
      html.light-mode .theme-btn .moon-icon {
        display: none;
      }

      /* Mobile Hamburger Menu */
      .mobile-menu-toggle {
        display: none;
        background: transparent;
        border: none;
        color: var(--text-color);
        font-size: 1.5rem;
      }

      /* Container layouts */
      main {
        padding-top: 80px;
      }

      /* Section Layout Utilities */
      section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 80px 24px;
        display: flex;
        flex-direction: column;
      }

      .slide-header-dots {
        display: flex;
        gap: 6px;
        margin-bottom: 20px;
      }
      .slide-header-dots .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--border-color);
      }
      .slide-header-dots .dot:nth-child(1) {
        background-color: var(--accent-color);
      }

      .section-divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(
          90deg,
          var(--border-color) 0%,
          transparent 100%
        );
        margin-bottom: 40px;
      }

      .section-title {
        font-family: var(--font-serif);
        font-size: 3rem;
        font-weight: 400;
        line-height: 1.2;
        margin-bottom: 12px;
      }
      .section-subtitle {
        font-family: var(--font-sans);
        font-size: 1.1rem;
        color: var(--accent-color);
        text-transform: uppercase;
        letter-spacing: 2px;
        font-weight: 600;
        margin-bottom: 30px;
      }

      /* Custom button styling matching Canva design lines */
      .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        background: var(--surface-color);
        border: 1px solid var(--accent-color);
        color: var(--text-color);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        border-radius: 4px;
        transition: all 0.3s ease;
      }
      .action-btn:hover {
        background: var(--accent-color);
        color: #121111;
        box-shadow: 0 5px 15px var(--accent-glow);
        transform: translateY(-2px);
      }

      /* Image Placeholders */
      .img-placeholder {
        background: var(--surface-color);
        border: 2px dashed var(--border-color);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-family: var(--font-sans);
        transition: border-color 0.3s ease;
      }
      .img-placeholder:hover {
        border-color: var(--accent-color);
      }
      .img-placeholder svg {
        width: 28px;
        height: 28px;
        opacity: 0.4;
      }

      /* HERO SECTION */
      .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        align-items: center;
        gap: 60px;
        min-height: 75vh;
      }
      .hero-title {
        font-family: var(--font-serif);
        font-size: 5rem;
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -1px;
        margin-bottom: 20px;
      }
      .hero-title span {
        font-weight: 700;
        display: block;
        color: var(--accent-color);
      }
      .hero-subtitle {
        font-family: var(--font-serif);
        font-size: 2.2rem;
        font-style: italic;
        font-weight: 400;
        color: var(--text-muted);
        margin-bottom: 30px;
      }
      .hero-globe {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid var(--border-color);
        color: var(--accent-color);
        margin-bottom: 30px;
      }
      .hero-visual {
        display: flex;
        justify-content: center;
        position: relative;
      }

      @media (max-width: 991px) {
        .hero-grid {
          grid-template-columns: 1fr;
          gap: 40px;
          text-align: center;
        }
        .hero-title {
          font-size: 3.5rem;
        }
        .hero-subtitle {
          font-size: 1.8rem;
        }
        .hero-content {
          display: flex;
          flex-direction: column;
          align-items: center;
        }
      }

      /* ABOUT SECTION */
      .about-grid {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 60px;
        align-items: center;
      }
      .about-visual {
        display: flex;
        justify-content: center;
      }
      .about-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }
      .about-bio {
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--text-color);
        margin-bottom: 24px;
        position: relative;
      }
      .about-bio p {
        margin-bottom: 16px;
      }
      .about-bio ul {
        list-style-type: none;
        margin-top: 10px;
      }
      .about-bio li {
        position: relative;
        padding-left: 20px;
        margin-bottom: 12px;
      }
      .about-bio li::before {
        content: "—";
        position: absolute;
        left: 0;
        color: var(--accent-color);
        font-weight: bold;
      }

      @media (max-width: 991px) {
        .about-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .about-content {
          align-items: center;
          text-align: center;
        }
        .about-bio li {
          text-align: left;
        }
      }

      /* TIMELINE & ACHIEVEMENTS */
      .achievement-block {
        display: flex;
        flex-direction: column;
        gap: 60px;
        margin-top: 20px;
      }
      .achievement-card {
        background-color: var(--bg-color-alt);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 40px;
        box-shadow: var(--shadow);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        align-items: center;
        transition: transform 0.3s ease;
      }
      .achievement-card:hover {
        transform: translateY(-4px);
      }
      .ach-year {
        font-family: var(--font-serif);
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--accent-color);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .ach-year::after {
        content: "";
        flex-grow: 1;
        height: 1px;
        background: linear-gradient(
          90deg,
          var(--accent-color) 0%,
          transparent 100%
        );
      }
      .ach-text {
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--text-color);
      }
      .ach-images {
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
      }

      @media (max-width: 991px) {
        .achievement-card {
          grid-template-columns: 1fr;
          gap: 30px;
          padding: 24px;
        }
        .ach-year {
          font-size: 2.8rem;
        }
      }

      /* LIGHT THEME ALTERNATING SECTIONS (Sports, Skills) */
      .alternate-bg {
        background-color: var(--bg-color-alt);
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        padding: 80px calc(50vw - 50% + 24px);
      }

      .sports-gallery {
        display: flex;
        flex-direction: column;
        gap: 40px;
      }
      .sports-grid-images {
        display: flex;
        justify-content: center;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 20px;
      }

      /* PERSONAL SKILLS */
      .skills-intro {
        font-size: 1.15rem;
        color: var(--text-color);
        max-width: 700px;
        margin-bottom: 40px;
        line-height: 1.6;
      }
      .skills-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 50px;
        align-items: center;
      }
      .skills-visuals {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }
      .skills-row-top {
        display: flex;
        gap: 20px;
      }
      .skills-list {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }
      .skill-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
      }
      .skill-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: var(--surface-color);
        border: 1px solid var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-color);
        flex-shrink: 0;
      }
      .skill-info h3 {
        font-family: var(--font-sans);
        font-size: 1.15rem;
        margin-bottom: 6px;
      }
      .skill-info p {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
      }

      @media (max-width: 991px) {
        .skills-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .skills-row-top {
          flex-direction: column;
        }
      }

      /* CAPSTONE PROJECT */
      .capstone-container {
        display: flex;
        flex-direction: column;
        gap: 40px;
      }
      .capstone-row {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 60px;
        align-items: center;
      }
      .capstone-row.reverse {
        grid-template-columns: 0.9fr 1.1fr;
      }
      .capstone-text {
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--text-color);
      }
      .capstone-text p {
        margin-bottom: 16px;
      }
      .capstone-visuals {
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .capstone-feature-box {
        background: var(--bg-color-alt);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 24px;
        margin-top: 20px;
      }
      .capstone-feature-box h4 {
        color: var(--accent-color);
        margin-bottom: 12px;
      }
      .capstone-feature-box ul {
        list-style: none;
      }
      .capstone-feature-box li {
        padding-left: 18px;
        position: relative;
        margin-bottom: 8px;
        font-size: 0.95rem;
      }
      .capstone-feature-box li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: var(--accent-color);
      }

      @media (max-width: 991px) {
        .capstone-row,
        .capstone-row.reverse {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .capstone-row.reverse .capstone-content {
          order: 2;
        }
        .capstone-row.reverse .capstone-visuals {
          order: 1;
        }
      }

      /* PROJECTS CARDS SHOWCASE (Slide 12) */
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 30px;
        margin-top: 20px;
      }
      .project-card {
        background-color: var(--bg-color-alt);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
        transition: transform 0.3s ease, border-color 0.3s ease;
      }
      .project-card:hover {
        transform: translateY(-6px);
        border-color: var(--accent-color);
      }
      .p-card-header {
        height: 180px;
        background: var(--surface-color);
        border-bottom: 1px solid var(--border-color);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .p-card-header img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
        transition: transform 0.5s ease, opacity 0.5s ease;
      }
      .project-card:hover .p-card-header img {
        transform: scale(1.05);
        opacity: 1;
      }
      .p-tag {
        position: absolute;
        top: 16px;
        left: 16px;
        background: var(--bg-color);
        color: var(--accent-color);
        border: 1px solid var(--accent-color);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      .p-card-body {
        padding: 24px;
      }
      .p-title {
        font-family: var(--font-serif);
        font-size: 1.4rem;
        margin-bottom: 10px;
        color: var(--text-color);
      }
      .p-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 20px;
      }

      /* CONTACT SECTION */
      .contact-window {
        max-width: 800px;
        width: 100%;
        margin: 40px auto;
        background-color: var(--bg-color-alt);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }
      .contact-content {
        padding: 50px;
      }
      .contact-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 40px;
        margin-top: 30px;
      }
      .contact-item {
        display: flex;
        align-items: center;
        gap: 20px;
      }
      .contact-circle-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background-color: var(--bg-color);
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-color);
        flex-shrink: 0;
        transition: border-color 0.3s ease, background 0.3s ease;
      }
      .contact-item:hover .contact-circle-icon {
        border-color: var(--accent-color);
        background: var(--surface-color);
      }
      .contact-circle-icon svg {
